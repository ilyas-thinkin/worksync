      "type": "file",
      "name": "db.config.js",
      "filePath": "src/config/db.config.js",
      "summary": "Configures and exports the shared PostgreSQL connection pool (pg.Pool) used across the entire backend, including a custom type parser that returns DATE columns as plain strings to avoid IST timezone off-by-one errors.",
      "tags": ["config", "database", "singleton", "entry-point"],
      "complexity": "simple",
      "languageNotes": "Overrides pg's default DATE (OID 1082) type parser globally so all queries in the app receive raw YYYY-MM-DD strings instead of UTC-shifted Date objects."
    },
