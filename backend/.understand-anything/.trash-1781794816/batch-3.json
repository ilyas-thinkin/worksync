    {
      "id": "file:src/scripts/run-system-rollback.js",
      "type": "file",
      "name": "run-system-rollback.js",
      "filePath": "src/scripts/run-system-rollback.js",
      "summary": "CLI script that rolls back a previously applied system update job: verifies a clean git worktree, restores the database from the most recent backup, resets the repository to the prior commit, and reports rollback status/log progress for a given job ID.",
      "tags": ["entry-point", "script", "deployment", "database", "git-operations"],
      "complexity": "complex",
      "languageNotes": "Heavy use of Node's child_process.spawn with manual stdout/stderr stream buffering to drive git, pg_restore/psql, and gunzip subprocesses sequentially."
    },
    {
      "id": "file:src/scripts/run-system-update.js",
      "type": "file",
      "name": "run-system-update.js",
      "filePath": "src/scripts/run-system-update.js",
      "summary": "CLI script that performs an in-place system update: checks out the latest commit, creates a rollback snapshot (db backup + commit ref), runs pre/post hook commands from the update plan, syncs environment files, and updates job status/log for a given job ID.",
      "tags": ["entry-point", "script", "deployment", "database", "automation"],
      "complexity": "complex",
      "languageNotes": "Mirrors run-system-rollback.js's command-running and git-status helpers, suggesting shared logic that could be further factored into utils."
    },
