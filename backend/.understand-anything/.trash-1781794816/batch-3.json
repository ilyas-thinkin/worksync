      "filePath": "src/utils/system-update-plan.js",
      "summary": "Loads and normalizes the system update plan configuration (JSON or JS module), merges it with built-in defaults, syncs declared environment files into place, and executes the plan's pre/post hook shell commands.",
      "tags": ["utility", "configuration", "automation", "deployment"],
      "complexity": "moderate"
    },
